# Copy this file to .env.local and fill in your values.
# Without these, EaseRead runs in "demo mode" (basic sentence splitting).
#
# Works with any OpenAI-compatible provider (Qwen Cloud, DashScope, OpenRouter, OpenAI...).
# Get the base URL, key, and model name from your provider's dashboard/docs.

LLM_API_KEY=your-api-key-here

# Base URL up to (and including) /v1 — do NOT include /chat/completions.
# Example (Alibaba DashScope intl): https://dashscope-intl.aliyuncs.com/compatible-mode/v1
LLM_BASE_URL=https://your-provider-base-url/v1

# Model name as named by your provider (e.g. qwen-plus, qwen-turbo, qwen2.5-7b-instruct)
LLM_MODEL=qwen-plus
