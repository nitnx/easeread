# Copy this file to .env.local and fill in your values.
# Without these, EaseRead runs in "demo mode" (basic sentence splitting).
#
# Works with any OpenAI-compatible provider. Configured below for
# Alibaba Cloud Model Studio (DashScope / Qwen Cloud).

LLM_API_KEY=your-dashscope-api-key-here

# OpenAI-compatible base URL (do NOT include /chat/completions).
LLM_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Recommended: a non-thinking model for fast, plain rewrites.
# qwen-plus is a good default; qwen-turbo is cheaper/faster.
LLM_MODEL=qwen-plus
